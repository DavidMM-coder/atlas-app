{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/messages.js": { "maxDuration": 300 },
    "api/fundamentals.js": { "maxDuration": 60 },
    "api/history.js": { "maxDuration": 30 },
    "api/fx.js": { "maxDuration": 15 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}
